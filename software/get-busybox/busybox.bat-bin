@echo off

if not exist %~dp0..\busybox_{{ version }}-windows64-x86\busybox.bat got win32
if "%PROCESSOR_ARCHITECTURE%"=="AMD64" goto win64
if "%PROCESSOR_ARCHITEW6432%"=="AMD64" goto win64
:win32
    %~dp0..\busybox_{{ version }}-windows-x86\busybox.bat %*
    goto end
:win64
    %~dp0..\busybox_{{ version }}-windows64-x86\busybox.bat %*
:end
