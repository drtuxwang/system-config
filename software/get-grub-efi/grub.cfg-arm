set default=0
set timeout=0
set superusers=""

# Use <ESC> for menu
timeout_style="hidden"

menuentry "Linux Virtual Machine    [EFI|vdb1]" --unrestricted {
    set root=(hd1,1)
    linux /boot/vmlinuz root=/dev/vdb1 quiet loglevel=3 noresume elevator=noop
    initrd /boot/initrd.img
}

menuentry "Linux Virtual Machine    [EFI|sdb1]" --unrestricted {
    set root=(hd1,1)
    linux /boot/vmlinuz root=/dev/sdb1 quiet loglevel=3 noresume elevator=noop
    initrd /boot/initrd.img
}
